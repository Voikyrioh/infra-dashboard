{
	"name": "dashboard-api",
	"version": "1.0.0",
	"main": "index.ts",
	"scripts": {
		"migrate:db": "db-migrate up",
		"migrate:db:down": "db-migrate down",
		"build": "node build.mjs",
		"dev": "tsx --tsconfig=tsconfig.json ./src/index.ts",
		"test": "mocha",
		"test:watch": "mocha --watch",
		"generate-key": "openssl genrsa -out ./.ssl/private.pem 2048 && openssl rsa -in ./.ssl/private.pem -pubout -out ./.ssl/public.pem"
	},
	"keywords": [
		"Dashboard"
	],
	"author": "Voikyrioh",
	"license": "ISC",
	"description": "API for the dashboard",
	"engines": {
		"node": "^24.4.0"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.9",
		"@hono/zod-validator": "^0.7.6",
		"@simplewebauthn/server": "^13.3.0",
		"argon2": "^0.44.0",
		"pino": "^9.7.0",
		"pino-pretty": "^13.0.0",
		"postgres": "^3.4.9",
		"ulid": "^3.0.2",
		"zod": "^4.0.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.2",
		"@types/chai": "^5.2.2",
		"@types/mocha": "^10.0.10",
		"@types/node": "^24.0.13",
		"chai": "^5.2.1",
		"db-migrate": "^0.11.14",
		"db-migrate-pg": "^1.5.2",
		"esbuild": "^0.28.0",
		"mocha": "^11.7.1",
		"tsx": "^4.20.3"
	}
}
