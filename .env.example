# Required for production deployment — copy to .env and fill in values

# Dashboard authentication
INIT_PASSWORD=          # min 24 chars, used for first WebAuthn setup

# JWT (RSA keys are mounted from /opt/dashboard/ssl/ — generated once on VPS)
JWT_EXPIRATION_TIME_MS=3600000

# PostgreSQL (provisioned via ansible/playbooks/provision-db.yml)
PG_USER=dashboard_user
PG_PASSWORD=

# GitHub integration
GITHUB_TOKEN=           # PAT with repo scope for app discovery

# Deployment
IMAGE_TAG=latest        # updated automatically by release.yml
